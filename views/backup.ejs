        function renderConnector(data) {
            let connectorTheme = ""
            let elmConnector = data.attributes.connector
            if (elmConnector.length > 1) {
                var connectorArr = elmConnector.join(" , ")
            } else {
                var connectorArr = elmConnector.join("")
            }
            connectorTheme += `
                <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                    <b class="c-black my-3">Cổng kết nối:</b> <span>${connectorArr}</span> 
                </div>
                `
            return connectorTheme
        }

        // The above code defines a function called `renderVGAData` that takes in a `data` object as a parameter. The function loops through the `VGA` array in the `attributes` property of the `data` object and generates HTML code for each VGA element. The generated HTML code includes the VGA name, VRAM, and connector information. The function then returns the generated HTML code as a string.
        function renderVGAData(data) {
            let vgaTheme = ""
            for (let i = 0; i < data.attributes.VGA.length; i++) {
                const elmVGA = data.attributes.VGA[i];
                if (elmVGA.connector.length > 1) {
                    var connectorArr = elmVGA.connector.join(" , ")
                } else {
                    var connectorArr = elmVGA.connector.join("")
                }
                vgaTheme += `
            <div class="col-sm-6 my-3 d-flex justify-content-between align-items-center col">
                <b class="c-black">VGA:</b> 
                <div>
                    <p class="text-center c-black">VGA ${i + 1}</p>
                    <p class="d-flex justify-content-between">  <span  class="c-black ">tên: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span>${elmVGA.name}</span></p>
                    <p class="d-flex justify-content-between">  <span class="c-black" >vram: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span>${elmVGA.vram.length > 0 ? elmVGA.vram : "không có"}</span></p>
                    <p class="d-flex justify-content-between">  <span class="c-black" >kết nối: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span> ${" " + connectorArr}</span></p>
                </div> 
            </div>
            `
            }
            return vgaTheme

        }
        // The above code defines a function called `renderHardDrivesData` that takes in a `data` parameter. The function loops through the `hardDrives` array in the `attributes` object of the `data` parameter and generates HTML code for each hard drive. The generated HTML code includes the type, brand, and size of each hard drive. The function then returns the generated HTML code as a string.
        function renderHardDrivesData(data) {
            let hardDrivesTheme = ""
            for (let i = 0; i < data.attributes.hardDrives.length; i++) {
                const elmHDR = data.attributes.hardDrives[i];
                hardDrivesTheme += `
            <div class="col-sm-6 my-3 d-flex justify-content-between align-items-center col">
                <b class="c-black">Ổ cứng:</b> 
                <div>
                    <p class="text-center c-black">Ổ số ${i + 1}</p>
                    <p class="d-flex justify-content-between">  <span  class="c-black ">Loại: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span>${elmHDR.type}</span></p>
                    <p class="d-flex justify-content-between">  <span class="c-black" >Hãng: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span>${elmHDR.brand.length > 0 ? elmHDR.brand : " "}</span></p>
                    <p class="d-flex justify-content-between">  <span class="c-black" >Dung lượng: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span>${elmHDR.size}</span></p>
                </div> 
            </div>
            `}
            return hardDrivesTheme

        }
        // The above code defines a function called `renderRamData` that takes in a parameter called `data`. The function loops through the `ram` attribute of the `data` object and creates a string of HTML elements that display the RAM information. The resulting HTML string is returned by the function.
        function renderRamData(data) {
            let ramTheme = ""
            for (let i = 0; i < data.attributes.ram.length; i++) {
                const elmRAM = data.attributes.ram[i];
                ramTheme += `
                    <p class="d-flex flex-cols justify-content-between">  <span  class="c-black ">Ram ${i + 1}: &nbsp&nbsp&nbsp&nbsp&nbsp</span>      <span>${elmRAM}</span></p>
            `}
            return ramTheme
        }
        // The above code defines a function called `removeData` that takes an argument `_id`. Within the function, it uses jQuery to select the element with the ID specified by the `_id` argument and empties its contents. This function can be used to remove the contents of an HTML element with a specific ID.
        function removeData(_id) {
            $(`#${_id}`).empty()
        }
        async function GetHistoryByIdDevice(id_device) {
            var result = await $.ajax({
                url: GVS.GetHistoryByIdDevice + `${id_device}`,
                method: "POST",
            })
            let html = ""
            result.metadata.forEach(elm => {

                html += `
            <div class="col-sm-6 col">
                <div class="d-flex justify-content-between my-2"><b class="c-black">${elm.type == 1 ? "Bàn giao cho:" : "Thu hồi của:"}</b> <span>${elm.staff.name}</span></div>
                <div class="d-flex justify-content-between my-2"><b class="c-black">${elm.type == 1 ? "Bàn giao bởi:" : "Thu hồi bởi:"}&nbsp&nbsp&nbsp&nbsp&nbsp</b> <span>${elm.user.name}</span></div>
                <div class="d-flex justify-content-between my-2"><b class="c-black">${elm.type == 1 ? "Ngày bàn giao:" : "Ngày thu hồi"}&nbsp&nbsp&nbsp&nbsp&nbsp</b> <span>${new Date(elm.createdAt).toLocaleDateString("vi-VN")}</span></div>
            </div>
            `
            });
            return html
        }
        const id = window.location.pathname.split('/').pop();
        function renderOptionHandover() {
            renderSelectOptionStaff()
            $.ajax({
                url: GVS.GetAllInventories,
                method: "GET",
                success: (res) => {
                    if (res.success == 1) {
                        renderSelectOptionHandover('case', res.metadata)
                        renderSelectOptionHandover('monitor', res.metadata)
                        renderSelectOptionHandover('wacom', res.metadata)
                        renderSelectOptionHandover('webcam', res.metadata)
                        renderSelectOptionHandover('headphone', res.metadata)
                    }
                    else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        })
                    }
                }
            })
        }
        function renderSelectOptionStaff() {
            $.ajax({
                url: GVS.GetStaffToHanover,
                method: "GET",
                success: (data) => {
                    let html = ""
                    html += `<option value = "">Chọn nhân viên bàn giao</option>`
                    data.metadata.forEach(elm => {
                        html += `
                        <optgroup class=" w-100" label="${elm._id}">                                                                                              `
                        for (let i = 0; i < elm.staff.length; i++) {
                            const element = elm.staff[i];
                            html += `
                            <option class="p-s-2" value="${element._id}">${element.name} - ${element.company} - ${element.job} - ${element.location.floor}</option>
                        </optgroup>`
                        }
                    });
                    $('#handover_staff').html(html)
                }
            })
        }
        function renderSelectOptionHandover(typeDevice, data) {
            data.forEach((device) => {
                if (device.type == typeDevice) {
                    let html = '';
                    html += `<option value = "">Chọn ${typeDevice} bàn giao</option>`
                    device.device.forEach((element) => {
                        if (parseInt(element.quantity) != 0) {
                            html += `<option value="${element.device._id}">${element.device.attributes && element.device.attributes.num ? element.device.attributes.num : ""} - ${element.device.name}</option>`
                        }
                    })
                    $('#handover_device_' + `${typeDevice}`).html(html)

                }
            })
        }
        $(document).ready(async () => {
            placeholderSelectHandoverDevice('case')
            placeholderSelectHandoverDevice('monitor')
            placeholderSelectHandoverDevice('webcam')
            placeholderSelectHandoverDevice('wacom')
            placeholderSelectHandoverDevice('headphone')

            $('#handover_staff').select2();
            $('#handover_staff').select2({
                dropdownParent: $('#handover'),
            });
            // checkStaffExsis()
        });
        function placeholderSelectHandoverDevice(typeDevice) {
            $(`#handover_device_${typeDevice}`).select2();
            $(`#handover_device_${typeDevice}`).select2({
                dropdownParent: $('#handover'),
                placeholder: `Chọn ${typeDevice} bàn giao`
            });
        }
        function revokeDevice(deviceId, id_modal) {
            const note = $('#floatingTextarea').val()
            const id_device = deviceId
            Swal.fire({
                title: "Bạn có chắc chắn muốn thu hồi thiết bị này không?",
                showDenyButton: true,
                confirmButtonText: "Có",
                denyButtonText: `Không`,
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: GVS.RevokeDevice,
                        method: "POST",
                        data: {
                            deviceId: id_device,
                            note
                        },
                        success: (data) => {
                            if (data.success == 1) {
                                Swal.fire({
                                    title: "Thông báo!",
                                    text: data.message,
                                    icon: "success",
                                    confirmButtonText: "OK",
                                }).then(() => {
                                    removeData(id_modal)
                                    $(`#${id_modal}`).modal('toggle')
                                }).then(async () => {
                                    await renderListDevice()
                                })
                            } else {
                                Swal.fire({
                                    title: "Thông báo!",
                                    text: data.message,
                                    icon: "error",
                                    confirmButtonText: "OK",
                                })
                            }
                        }
                    })
                }
            })

        }
        function changePreviewSelect(e, nameSelect) {
            if ($(e).val() != "") {
                if (nameSelect == "staff") {
                    $(`#preview_select_${nameSelect} `).text($(`#handover_${nameSelect} option:selected`).text())
                }
                else {
                    var selectedTexts = $(`#handover_device_${nameSelect}`).find('option:selected').map(function () {
                        return $(this).text();
                    }).get();
                    $(`#preview_select_${nameSelect} `).text(selectedTexts.join(" , "))
                }
            }
            else {
                $(`#preview_select_${nameSelect}`).text("")
            }


        }
        function checkDataHandover() {
            const vlaueStaff = $('#handover_staff option:selected').val()
            if (vlaueStaff == "") {
                Swal.fire({
                    title: "Thông báo!",
                    text: "Vui lòng chọn nhân viên muốn bàn giao!",
                    icon: "error",
                    confirmButtonText: "OK",
                })
            }
            else {
                let ids = []
                ids = [...ids, ...$('#handover_device_case').val(), ...$('#handover_device_monitor').val(), ...$('#handover_device_wacom').val(), ...$('#handover_device_headphone').val(), ...$('#handover_device_webcam').val()]
                const valueNote = $('#note_handover').val()

                if (ids.length != 1) {
                    handoverDeviceAll(vlaueStaff, ids, valueNote)
                }
                else {
                    handoverDevice(vlaueStaff, ids[0], valueNote)

                }
            }
        }
        function handoverDeviceAll(staff, ids, note) {
            $.ajax({
                url: GVS.handoverDeviceAll,
                method: "POST",
                header: {
                    "Content-Type": "application/json"
                },
                data: {
                    staff: staff,
                    ids: ids,
                    note: note
                },
                success: (res) => {
                    if (res.success == 1) {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "success",
                            confirmButtonText: "OK",
                        }).then(() => {
                            $(`#handover`).modal('toggle')
                        }).then(async () => {
                            await renderListDevice()
                        })
                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        })
                    }
                }

            })
        }
        function handoverDevice(staff, id, note) {
            $.ajax({
                url: GVS.Hanover,
                method: "POST",
                header: {
                    "Content-Type": "application/json"
                },
                data: {
                    staff: staff,
                    deviceId: id,
                    note: note
                },
                success: (res) => {
                    if (res.success == 1) {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "success",
                            confirmButtonText: "OK",
                        }).then(() => {
                            $(`#handover`).modal('toggle')
                        }).then(async () => {
                            await renderListDevice()
                            deleteInput("note_handover")
                        })
                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        })
                    }
                }

            })
        }
        function deleteInput(id) {
            $(".js-example-basic-multiple").val([]).trigger('change')
            $("#preview_select_staff").text("")

            $(`#${id}`).val("")
        }
        function revokeAllDevice(idStaff, name, company, job) {
            Swal.fire({
                title: "Bạn có chắc chắn muốn thu hồi thiết bị này không?",
                showDenyButton: true,
                confirmButtonText: "Có",
                denyButtonText: `Không`,
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: GVS.revokeDeviceAll,
                        method: "POST",
                        header: {
                            "Content-Type": "application/json"
                        },
                        data: {
                            idStaff: idStaff,
                            note: `Thu hồi tất cả thiết bị của ${name}-${company}-${job}`
                        },
                        success: (res) => {
                            if (res.success == 1) {
                                Swal.fire({
                                    title: "Thông báo!",
                                    text: res.message,
                                    icon: "success",
                                    confirmButtonText: "OK",
                                })
                                    .then(async () => {
                                        await renderListDevice()
                                    })
                            } else {
                                Swal.fire({
                                    title: "Thông báo!",
                                    text: res.message,
                                    icon: "error",
                                    confirmButtonText: "OK",
                                })
                            }
                        }

                    })
                }
            })

        }
    </script>

</html>