    <script>
        $(document).ready(async () => {
            await renderDeviceSummary()
            await renderListDevice()
            await $("#table-index").DataTable({
                rowGroup: true
            });
        })

        var datas;
        async function renderStaffSummary() {
            const staff = await $.ajax({
                url: GVS.GetStaffSummary,
                method: "GET",
            })
            let html = ""
            staff.metadata.forEach((elm) => {
                html += `
                <div class="col-xl-2 col-md-6 mb-4" id="staff__index">
                    <div class="card border-left-staff shadow h-100 py-2">
                        <div class="card-body pb-1 align-items-center">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2">
                                    <div class="text-xs f-s-18 font-weight-bold text-primary text-uppercase mb-1">
                                        Nhân sự</div>
                                    <div class="d-flex flex-column">
                                    <a href="${GVS.CreateStaff}" class="link__device--index text-decoration-none text-black f-s-16 mb-0 font-weight-bold  " href="#" data-bs-toggle="tooltip" data-bs-title="Default tooltip">Tổng số: ${elm.total} </a>
                                    <a href="${GVS.CreateStaff}?status=1" class="link__device--index text-decoration-none text-black f-s-16 mb-0 font-weight-bold  " href="#" data-bs-toggle="tooltip" data-bs-title="Default tooltip">Đang làm: ${elm.is_working} </a>
                                    </div>
                                    
                                </div>
                                <div class="col-auto">
                                    <!-- fas fa-calendar -->
                                    <i class="fa fa-users nav_icon fa-2x text-gray-300"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                `
            })
            return html
        }
        // danh sách số lương thiết bị sắp xếp
        let arrDeviceSort = ['case', 'monitor', 'wacom', 'webcam', 'headphone']
        function sortArrayByAnotherArray(array1, array2) {
            return array1.sort((a, b) => {
                const aIndex = array2.findIndex(item => item === a._id);
                const bIndex = array2.findIndex(item => item === b._id);
                if (aIndex === -1) {
                    return 1;
                }
                if (bIndex === -1) {
                    return -1;
                }
                return aIndex - bIndex;
            });
        }
        function renderDeviceSummary(params) {
            $.ajax({
                url: GVS.GetDeviceSummary,
                method: "GET",
                success: async (data) => {
                    if (data.success == 1) {
                        sortArrayByAnotherArray(data.metadata, arrDeviceSort)
                        let html = ""
                        html += await renderStaffSummary()
                        data.metadata.forEach((elm) => {
                            html += `
                            <div class="col-xl-2 col-md-6 mb-4">
                                <div class="card ${elm._id == "headphone" ? "border-left-headphone" :
                                    elm._id == "webcam" ? "border-left-webcam" :
                                        elm._id == "case" ? "border-left-case" :
                                            elm._id == "monitor" ? "border-left-monitor" : "border-left-wacom"
                                } shadow h-100 py-2">
                                    <div class="card-body pb-1 align-items-center">
                                        <div class="row no-gutters align-items-center">
                                            <div class="col mr-2 ">
                                                <div class="text-xs f-s-18  ${elm._id == "headphone" ? "text-headphone" :
                                    elm._id == "webcam" ? "text-webcam" :
                                        elm._id == "case" ? "text-case" :
                                            elm._id == "monitor" ? "text-monitor" : "text-wacom"
                                } font-weight-bold  text-uppercase mb-1">


                                                    ${elm._id == "headphone" ? "Tai nghe" :
                                    elm._id == "case" ? "Máy tính" :
                                        elm._id == "monitor" ? "Màn hình" :
                                            elm._id == "wacom" ? "wacom" :
                                                elm._id == "headphone" ? "Tai nghe" : "webcam"
                                }

                                                    </div>
                                               <div class="d-flex flex-column">
                                                <a href="${GVS.GETALLDEVICE}/${elm._id}"  class="link__device--index text-decoration-none f-s-16 mb-0 font-weight-bold
                                                
                                                text-black ">
                                                
                                                Tổng số: ${elm.total}
                                                </a>
                                               <a href="${GVS.GETALLDEVICE}/${elm._id}?status=1" class="link__device--index text-decoration-none f-s-16 mb-0 font-weight-bold text-black ">Chưa dùng: ${elm.not_inuse}</a>
                                                </div>

                                            </div>
                                            <div class="col-auto">
                                                <!--  -->
                                                <i class="${elm._id == "headphone" ? "bx bx-headphone" :
                                    elm._id == "webcam" ? "bx bxs-webcam" :
                                        elm._id == "case" ? "bx bx-speaker" :
                                            elm._id == "monitor" ? "bx bx-desktop" : "bx bx-tab"
                                } nav_icon  fa-2x text-gray-300">
                                                </i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            `
                        })
                        $('#device__index').html(html)
                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: data.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        })
                    }
                }
            })
        }
        function renderListDevice() {
            var html = ""
            $.ajax({
                url: GVS.GETALLDEVICE,
                method: "GET",
                success: (data) => {
                    datas = data.metadata
                    data.metadata.forEach((elm, index) => {
                        html += `<tr>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle text-max-content" scope="row"><button class="btn badge bg-danger p-2" onclick = "revokeAllDevice('${elm.staff._id}','${elm.staff.name}','${elm.staff.company}','${elm.staff.job}')">Thu hồi tất cả</button></td>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle text-max-content" scope="row">${elm.staff.name}</td>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle" scope="row">${elm.staff.company}</td>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle" scope="row">${elm.staff.job}</td>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle" scope="row">${elm.staff.location.address}</td>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle" scope="row">${elm.staff.location.floor}</td>
                            <td rowspan="${elm.devices.length + 1}" class="align-middle" scope="row">${elm.staff.phoneNumber}</td>`

                        for (let i = 0; i < elm.devices.length; i++) {
                            const el = elm.devices[i];
                            html += `
                            <tr>
                                <td class="align-middle link__device--detail"  scope="row">
                                    <a data-bs-toggle="tooltip" data-bs-title="Default tooltip" class="" 
                                        onclick="${el.type == "case" ? `caseModal('${el._id}','${elm.staff._id}')` :
                                    el.type == "monitor" ? `monitorModal('${el._id}','${elm.staff._id}')` :
                                        el.type == "wacom" ? `wacomModal('${el._id}','${elm.staff._id}')` :
                                            el.type == "webcam" ? `webcamModal('${el._id}','${elm.staff._id}')` : `headphoneModal('${el._id}','${elm.staff._id}')`}">${el.attributes.num}-${el.name}
                                    </a>
                                </td>
                                <td class="align-middle" scope="row">${el.type}</td>
                                <td class="align-middle" scope="row">${el.supplier.name}</td>
                                <td class="align-middle" scope="row">${el.location.address}</td>
                                <td class="align-middle" scope="row">${el.location.floor}</td>
                                <td class="align-middle" scope="row">${el.status == 0 ? "Đang sử dụng" : el.status == 1 ? "Có thể sử dụng" : "Hỏng"}</td>
                            </tr>`
                        }
                        html += `</tr>`
                    });
                    $("#dataDevice").html(html)
                }
            })
        }

        async function monitorModal(_id, staffId) {
            const staff = datas.find(_ => _.staff._id == staffId)
            if (!staff) {
                //////
                return
            }
            const data = staff.devices.find(_ => _._id == _id)
            let monitorTheme = ""
            monitorTheme += `
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header justify-content-center c-black f-s-22">

                                <!-- <h1 class="modal-title fs-5" id="">Case</h1> -->
                                <div>Chi tiết Monitor</div>
                                
                                <button type="button" onclick="removeData('data-Detail')" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body f-s-18" id="">
                                <div class="container">
                                    <div class="row justify-content-end my-3">
                                        <a class="col-sm-5 col-lg-4 col text-decoration-none text-end" href="${GVS.GetDetailDevice}${_id}">
                                            Trang chi tiết của thiết bị
                                            <i class="fa fa-sharp fa-solid fa-forward"></i>
                                        </a>
                                    </div>
                                    
                                    <div class="row">
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                           <b class="c-black my-3">Tên thiết bị:</b> <span>${data.name}</span>
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3"> Loại thiết bị:</b> <span>${data.type}</span>
                                            </div>
                                            <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                           <b class="c-black my-3">Địa chỉ thiết bị:</b> <span>${data.location.address}</span> 
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Tầng đặt thiết bị:</b> <span>${data.location.floor}</span>
                                            </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                                <b class="c-black my-3">Nhà cung cấp:</b> <span>${data.supplier.name}</span>
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Giá theo hóa đơn:</b> <span>${data.billPrice}</span> 
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Tổng giá trị:</b> <span>${data.totalPrice}</span> 
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Thời hạn bảo hành:</b> <span>${new Date(data.expirationDate).toLocaleDateString("vi-VN")}</span>
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Ngày tạo:</b> <span>${new Date(data.createdAt).toLocaleDateString("vi-VN")}</span>
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Ngày cập nhật gần đây:</b> <span>${new Date(data.updatedAt).toLocaleDateString("vi-VN")}</span> 
                                        </div>
                                        ${renderConnector(data)}
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                           <b class="c-black my-3">số:</b> <span>${data.attributes.num}</span> 
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                            <b class="c-black my-3">Trạng thái:</b> <span>${data.status == 0 ? "Đang sử dụng" : 1 ? "Có thể sử dụng" : "Hỏng"}</span> 
                                        </div>
                                        <div class="col-sm-6 d-flex justify-content-between align-items-center col">
                                           <b class="c-black my-3">Ghi chú:</b> <span>${data.note}</span> 
                                        </div>
                                    </div>
                                    <div class="row my-3 align-items-center justify-content-center">
                                        <b class="col-12 c-black text-center">
                                            Lịch sử thiết bị
                                        </b>
                                    </div>
                                    
                                    <div class="row  align-items-center " >
                                        ${await GetHistoryByIdDevice(_id)}
                                    </div>
                                    <div class="row my-3 align-items-center justify-content-center">
                                        <b class="col-12 c-black text-center">
                                            Tạo ghi chú thu hồi (nếu có)
                                        </b>
                                    </div>
                                    <div class="row my-3 justify-content-center">
                                        <div class="form-floating">
                                            <textarea class="form-control" placeholder="Leave a comment here"
                                                id="floatingTextarea"></textarea>
                                            <label for="floatingTextarea">Ghi chú:</label>
                                        </div>
                                    </div>
