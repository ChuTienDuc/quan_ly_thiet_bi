        // }
        function formatDate(date) {
            var d = new Date(date),
                month = '' + (d.getMonth() + 1),
                day = '' + d.getDate(),
                year = d.getFullYear();

            if (month.length < 2)
                month = '0' + month;
            if (day.length < 2)
                day = '0' + day;

            return [year, month, day].join('-');
        }
        let statusComponent
        let quantityComponent

        function changeInputUpdate(id) {
            $("#button_update_component").attr("onclick", `updateComponent('${id}')`)
            dataComponent.forEach((component) => {
                if (component._id == id) {
                    $("#type_update_component").val(component.attributes.type)
                    $("#bill_price_update").val(component.billPrice).attr("disabled", true)
                    $("#total_price_update").val(component.totalPrice)
                    $("#expirationDate_updatecomponent").val(formatDate(component.expirationDate))
                    $("#note_updatecomponent").val(component.note)
                    $("#type_update_component").attr("disabled", true)
                    formatCurrency($("#bill_price_update"))
                    formatCurrency($("#total_price_update"))
                    changeAddComponent(component.attributes.type, "update")
                    $('#status_component').val(component.status)
                    $('#data_status__component').removeClass('d-none')
                    if (component.quantity == 0) {
                        $('#data_status__component').addClass('d-none')
                        statusComponent = component.status
                        // $('button_update_component').off()
                    }
                    quantityComponent = component.quantity

                    if (component.attributes.type == "ram") {
                        $(`#${component.attributes.type}_update`).val(component.attributes.attributes)
                    } else if (component.attributes.type == "VGA") {

                        $("#VGA_name_update").val(component.attributes.attributes.name)
                        $("#VGA_vram_update").val(component.attributes.attributes.vram)
                        $("#VGA_connector_update").val(component.attributes.attributes.connector)
                    } else if (component.attributes.type == "hardDrives") {
                        $("#hardDrives_size_update").val(parseInt(component.attributes.attributes.size))
                        fomatValue($("#hardDrives_size_update"))
                        $("#hardDrives_type_update").val(component.attributes.attributes.type)
                        $("#hardDrives_brand_update").val(component.attributes.attributes.brand)
                    } else {
                        $(`#${component.attributes.type}_update`).val(component.attributes.attributes.name)

                    }
                }
            })
        }

        function updateComponent(id) {
            let status
            if (quantityComponent !== 0) {
                status = $('#status_component').val()
            } else {
                status = statusComponent
            }
            var dataUpdateComponent = {
                type: "component",
                supplier: $("#supplier_updatecomponent").val(),
                attributes: {
                    attributes: getInputAttributes("_update")
                },
                status,
                totalPrice: parseInt($("#total_price_update").val().replace(',', "")),
                expirationDate: $("#expirationDate_updatecomponent").val(),
                note: $("#note_updatecomponent").val(),
            }
            $.ajax({
                url: GVS.UpdateDevice + `${id}`,
                method: "PATCH",
                data: dataUpdateComponent,
                success: (res) => {
                    if (res.success == 1) {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "success",
                            confirmButtonText: "OK",
                        }).then((result) => {
                            $("#button_cancel_update_component").click()
                            getAllComponent()

                        });
                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        });
                    }
                }
            })
        }

