        function fomatValue(e) {
            if ($(e).val() != "" && $(e).val().substring($(e).val().length - 2) != "GB" && $(e).val().substring($(e).val()
                .length - 2) != "TB") {
                if ($(e).val() < 100) {
                    $(e).attr("type", "text")
                    $(e).val($(e).val() + "TB")
                } else {
                    $(e).attr("type", "text")
                    $(e).val($(e).val() + "GB")
                }
            }
        }

        function fomatValueSize(e) {
            if ($(e) == '') return
            $(e).val(parseInt($(e).val()))
            $(e).select()

