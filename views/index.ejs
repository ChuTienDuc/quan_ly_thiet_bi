            position: absolute;
            bottom: 10%;
            right: -2%;
        }

        .circle1 {
            z-index: -1;
            border-radius: 374.276px;
            background: linear-gradient(180deg, rgba(123, 80, 243, 0.20) 0%, rgba(255, 255, 255, 0.00) 100%);
            width: 374.43px;
            height: 404.276px;
            transform: rotate(104.585deg);
            position: absolute;
            top: -11%;
            left: 5%;
        }

        @keyframes backgroundanimation {
            from {
                transform: translate(0, 0);
            }

            to {
                transform: translate(-100px, 100px);
            }
        }

        @keyframes bg-device-style {
            from {
                color: rgb(10, 20, 108);

            }

