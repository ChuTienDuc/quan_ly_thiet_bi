    <script>
        $(document).ready(() => {
            renderDeviceSummary()
            renderListDevice()
        })

        var datas;
        async function renderStaffSummary() {
            const staff = await $.ajax(GVS.setting(GVS.GetStaffSummary, 'GET'))
            let html = ""
            staff.metadata.forEach((elm) => {
                html += `
                <div class="col-4 mb-4 d-inline-flex position-relative" id="staff__index">
                    <div class="card h-100 py-2" style="box-shadow: none; position: relative; left: 50%; transform: translateX(-25%); width: 155px" onmouseover="hoverChangeBgColor(this)" onmouseout="hoverDeleteChangeBgColor(this)">
                        <div class="card-body pb-1 align-items-center">
                            <div class="row no-gutters align-items-center">
                                <div class="col mr-2 device-style" >
                                    <div class="text-xs f-s-18 font-weight-bold text-uppercase mb-3">
                                        Nhân sự</div>
                                    <div class="d-inline-flex flex-column">
                                    <a href="${GVS.CreateStaff}" class="link__device--index text-decoration-none f-s-16 mb-0 font-weight-bold  device-text" href="#" data-bs-toggle="tooltip" data-bs-title="Default tooltip">Tổng số: ${elm.total} </a>
                                    <a href="${GVS.CreateStaff}?status=1" class="link__device--index text-decoration-none f-s-16 mb-0 font-weight-bold  device-text" href="#" data-bs-toggle="tooltip" data-bs-title="Default tooltip">Đang làm: ${elm.is_working} </a>
                                    </div>                                 
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="line-device"></div>
                </div>
                `
            })
            return html
        }
