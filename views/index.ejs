        function customMatcher(params, data) {
            // Nếu không có thuộc tính tìm kiếm, trả về tất cả dữ liệu
            if ($.trim(params.term) === '') {
                return data;
            }

            // Tìm kiếm không phân biệt chữ hoa chữ thường
            if (typeof data.text === 'undefined') {
                return null;
            }

            // Đơn giản hóa cả chuỗi tìm kiếm và dữ liệu để loại bỏ dấu
            var term = params.term.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();
            var text = data.text.normalize('NFD').replace(/[\u0300-\u036f]/g, '').toLowerCase();

            if (text.indexOf(term) > -1) {
                var modifiedData = $.extend({}, data, true);
                return modifiedData;
            }

            // Trả về `null` để ẩn lựa chọn không khớp
            return null;
        }
