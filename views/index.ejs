            width: max-content !important;
            text-align: center;
        }

        #table-index,
        #table-index_1 td,
        #table-index,
        #table-index_1 th {
            vertical-align: middle;
            text-align: center;
        }

        .select2-selection__rendered {
            text-overflow: ellipsis;
            white-space: nowrap;
            overflow: hidden;
            max-width: 100%;
        }

        .select2-selection--multiple {
            overflow: hidden;
            white-space: nowrap;
            max-width: 100%;
        }

        .select2-container--below {
            width: 100% !important;
        }

        .nav-pills .nav-link {
            background: #C4D3D6;

            color: #fff;

        }

        .nav-pills .nav-link.active {
            background: #0085FF !important;
        }

        #pills-profile-tab:hover {
            cursor: pointer;
            background: #0085FF;
            ;
            animation-name: background-btn;
