    <script type="module">
        import { handoverType0HTML } from '/javascripts/custom_handover/handoverPDF/handoverType0HTML.js';
        import { handoverType1HTML } from '/javascripts/custom_handover/handoverPDF/handoverType1HTML.js';
        import { handoverType2HTML } from '/javascripts/custom_handover/handoverPDF/handoverType2HTML.js';
        $(document).ready(() => {
            dataHandover()
        })
        var handovers = [];
        var idPDF = '';

        function dataHandover() {
            const urlParams = new URLSearchParams(window.location.search);
            const isOpenParam = urlParams.get('isOpen')
            $.ajax({
                url: `${isOpenParam == null ? '/api/handover/getAll' : '/api/handover/getAll?isOpen=true'}`,
                method: "GET",
                beforeSend: function () {
                    $('.background').removeClass('hidden');
                },
                success: (res) => {
                    handovers.push(res.metadata)
                    renderHandover(res.metadata)
                    $("#table_handover").DataTable().destroy()
                    $("#table_handover").DataTable({
                        "pageLength": 50,
                        lengthMenu: [20, 40, 50, 100, 200, 500],
                    })
                    previewPDF(res.metadata)
                },
                complete: function () {
                    $('.background').addClass('hidden');
                }
            })
        }

        // danh sách số lương thiết bị sắp xếp
        let arrDeviceSort = ["case", "monitor", "wacom", "headphone", "webcam", "component", "ups", "mouse", "keyboard"]

        function sortArrayByAnotherArray(array1, array2) {
            return array1.sort((a, b) => {
                const aIndex = array2.findIndex(item => item === a.type);
                const bIndex = array2.findIndex(item => item === b.type);
                if (aIndex === -1) {
                    return 1;
                }
                if (bIndex === -1) {
                    return -1;
                }
                return aIndex - bIndex;
            });
        }

        // function renderHanoverOpenWithUserId(dataBefore) {
        //     const urlParams = new URLSearchParams(window.location.search);
        //     const isOpenParam = urlParams.get('isOpen')
        //     const userIdParam = urlParams.get('user')
        //     // const userIdParam = urlParams.get('user')
        //     let dataAfter
        //     if (isOpenParam !== null && userIdParam !== null) {
        //         dataAfter = dataBefore.filter(_ => _.isOpen == JSON.parse(isOpenParam) && _.user._id == userIdParam)

        //     } else {
