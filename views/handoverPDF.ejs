        function renderHandover(handovers) {
            console.log(handovers)
            var html = ''
            handovers.sort((a, b) => (a.createdAt === b.createdAt) ? 0 : a.createdAt ? -1 : 1);
            handovers.sort((a, b) => (a.isOpen === b.isOpen) ? 0 : a.isOpen ? -1 : 1);
            // var datas = renderHanoverOpenWithUserId(handovers)
            handovers.forEach((elm, index) => {
                const typeMapping = {
                    "mouse": "chuột",
                    "keyboard": "bàn phím",
                };
                if (elm.isOpen == 0) {
                    html += `
                <tr class= "align-middle" id="info">
                    <td class="text-center">${index + 1}</td>
                    <td class="text-center">${elm.staff.name}</td>
                    <td class="text-center">${elm.staff.location.address}</td>
                    <td class="text-center">${elm.staff.location.floor}</td>
                    <td class="text-center">`
                    if (elm.type == 1 || elm.type == 2) {
                        elm.deviceHandover.forEach((device) => {
                            console.log(device)
                            if (device.type === 'component') {
                                const componentTypes = {
                                    "hardDrives": `${device.attributes.type || ""} - ${device.attributes.attributes.size || ""} ${device.attributes.attributes.type || ""} ${device.attributes.attributes.brand || ""}`,
                                    "mainBoard": `${device.attributes.type || ""} - ${device.attributes.attributes.name || ""}`,
                                    "VGA": `${device.attributes.type || ""} - ${device.attributes.attributes.name || ""} ${device.attributes.attributes.vram || ""}`,
                                    "ram": `${device.attributes.type || ""} - ${device.attributes.attributes || ""}`,
                                    "PSU": `${device.attributes.type || ""} - ${device.attributes.attributes.name || ""}`,
                                    "chipset": `${device.attributes.type || ""} - ${device.attributes.attributes.name || ""}`,
                                };

                                html +=
                                    `<div class="text-center">${componentTypes[device.attributes.type] || ""}</div>`;
                            } else if (device.type === "mouse" || device.type === "keyboard") {
                                const translatedType = typeMapping[device.type] || device.type;
                                html += `<div class="text-center">${translatedType || ""}</div>`;
                            } else {
                                html +=
                                    `<div class="text-center">${device.type || ""} - ${device.attributes.num || ""}</div>`;
                            }

                        });
                    }
                    if (elm.type == 2 || elm.type == 0) {
                        elm.deviceRevoke.forEach((device) => {
                            console.log("1", device);

                            if (["mainBoard", "ram", "PSU", "chipset"].includes(device.type_component)) {
                                html += `<div>${device.type_component || ""} - ${device.name || ""}</div>`;
                            } else if (device.type_component === 'VGA') {
                                html += `<div>${device.name || ""} - ${device.vram || ""}</div>`;
                            } else if (device.type_component === "hardDrives") {
                                html +=
                                    `<div class="text-center">${device.type || ""} - ${device.brand || ""} - ${device.size || ""}</div>`;
                            } else if (["mouse", "keyboard"].includes(device.type)) {
                                const translatedType = typeMapping[device.type] || device.type;
                                html += `<div class="text-center">${translatedType || ""}</div>`;
                            } else if (["case", "monitor", "wacom", "webcam", "headphone", "ups"].includes(
                                device.type)) {
                                console.log(device);
                                html +=
                                    `<div class="text-center">${device.type || ""} - ${device.attributes.num || ""}</div>`;
                            }

                        });
                    }
                    html += `
                            </td>
                            <td class="text-center">${new Date(elm.createdAt).toLocaleDateString("vi-VN")}</td>
                            <td class="text-center">${elm.note}</td>
                            <td class="text-center">
                                <a onclick="previewPDF('${elm._id}')" class="text-decoration-none text-white">
                                    <button type="button" id="preview" class="btn bg-color-all c-white" data-bs-toggle="modal" data-bs-target="#exampleModal">
                                        Xem Chi Tiết
                                    </button>
                                </a>
                            </td>
                    </tr >`
                }
                if (elm.isOpen == 1) {
                    html += `
                    <tr class= "align-middle bg-yellow" id="info1">
                        <td class="text-center">${index + 1}</td>
                        <td class="text-center">${elm.staff.name}</td>
                        <td class="text-center">${elm.staff.location.address}</td>
                        <td class="text-center">${elm.staff.location.floor}</td>
                        <td class="text-center">`
                    if (elm.type == 1 || elm.type == 2) {
                        elm.deviceHandover.forEach((device) => {
                            if (device.type == 'component') {
                                const attributes = device.attributes;
                                const type = attributes.type || "";
                                const size = attributes.attributes?.size || "";
                                const brand = attributes.attributes?.brand || "";
                                const name = attributes.attributes?.name || "";
                                const vram = attributes.attributes?.vram || "";

                                const componentType = {
                                    "hardDrives": `${type || ""} - ${size || ""} ${type || ""} ${brand || ""}`,
                                    "mainBoard": `${type || ""} - ${name || ""}`,
                                    "VGA": `${type || ""} - ${name || ""} ${vram || ""}`,
                                    "ram": `${type || ""} - ${name || ""}`,
                                    "chipset": `${type || ""} - ${name || ""} ${vram || ""}`,
                                    "PSU": `${type || ""} - ${name || ""}`
                                };

                                html += `<div class="text-center">${componentType[type] || ""}</div>`;
                            } else if (device.type == "mouse" || device.type == "keyboard") {
                                const translatedType = typeMapping[device.type] || device.type;
                                html += `<div class="text-center">${translatedType || ""}</div>`;
                            } else {
                                const type = device.type || "";
                                const num = device.attributes?.num || "";
                                html += `<div class="text-center">${type || ""} - ${num || ""}</div>`;
                            }
                        });
                    }
                    if (elm.type == 2 || elm.type == 0) {
                        elm.deviceRevoke.forEach((device) => {
                            if (device.type == 'component') {
                                const attributes = device.attributes;
                                const type = attributes.type || "";
                                const size = attributes.attributes?.size || "";
                                const brand = attributes.attributes?.brand || "";
                                const name = attributes.attributes?.name || "";
                                const vram = attributes.attributes?.vram || "";

                                const componentType = {
                                    "hardDrives": `${type || ""} - ${size || ""} ${type || ""} ${brand || ""}`,
                                    "mainBoard": `${type || ""} - ${name || ""}`,
                                    "VGA": `${type || ""} - ${name || ""} ${vram || ""}`,
                                    "ram": `${type || ""} - ${name || ""}`,
                                    "chipset": `${type || ""} - ${name || ""} ${vram || ""}`,
                                    "PSU": `${type || ""} - ${name || ""}`
                                };

                                html += `<div class="text-center">${componentType[type] || ""}</div>`;
                            } else if (device.type == "mouse" || device.type == "keyboard") {
                                const translatedType = typeMapping[device.type] || device.type;
                                html += `<div class="text-center">${translatedType || ""}</div>`;
                            } else {
                                const type = device.type || "";
                                const num = device.attributes?.num || "";
                                html += `<div class="text-center">${type || ""} - ${num || ""}</div>`;
                            }
                        });
                    }
                    html += `
                            </td>
                            <td class="text-center">${new Date(elm.createdAt).toLocaleDateString("vi-VN")}</td>
                            <td class="text-center">${elm.note}</td>
                            <td class="text-center">
                                <a onclick="previewPDF('${elm._id}')" class="text-decoration-none text-white">
                                    <button type="button" id="preview" class="btn bg-color-all c-white" data-bs-toggle="modal" data-bs-target="#exampleModal">
                                        Xem Chi Tiết
                                    </button>
                                </a>
                            </td>
                    </tr >`
                }
            });

            $("#content_table").html(html)
        }

        function previewPDF(id, index) {
            handovers.forEach(data => {
                data.forEach(elm => {
                    if (elm._id == id) {
                        const dataDate = extractDataDate(elm.createdAt);
                        let htmls = '';
                        switch (elm.type) {
                            case 0:
                                htmls = handoverType0HTML(elm, dataDate, typeComponentObj);
                                break;
                            case 1:
                                htmls = handoverType1HTML(elm, dataDate, typeComponentObj);
                                break;
                            case 2:
                                htmls = handoverType2HTML(elm, dataDate, typeComponentObj);
                                console.log(typeComponentObj);
                                console.log(elm);
                                break;
                            default:
                                htmls = "Invalid type";
                        }
                        $("#content-pdf").html(htmls);
                    }
                });
            });
        }
        var typeComponentObj = {
            "ram": "Ram",
            "hardDrives": "Ổ cứng",
            "chipset": "Chipset",
            "mainBoard": "Bo mạch chủ",
            "VGA": "VGA",
            "PSU": "PSU",
            "mouse": "Chuột FUHLEN",
            "keyboard": "Bàn phím FUHLEN",
            "Dấu Cộng": "Công ty Cổ phần Phần mềm Dấu Cộng",
            "Minh Việt": "Công ty Cổ phần Dịch vụ và Truyền thông Minh Việt"
        };

        window.typeComponentObj = typeComponentObj;
        window.previewPDF = previewPDF;
        window.printPDF = printPDF;
        window.exportAll = exportAll;
        window.confirmExportAll = confirmExportAll;


        function extractDataDate(createdAt) {
            const date = new Date(createdAt);
            return {
                day: date.getDate(),
                month: date.getMonth() + 1,
                year: date.getFullYear()
            };
        }

        var linkPDF = ''

        function setCsrfHeader(xhr) {
            const meta = document.querySelector('meta[name="csrf-token"]');
            if (meta) {
                xhr.setRequestHeader('CSRF-Token', meta.getAttribute('content'));
            }
        }

        function printPDF(id) {
            $.ajax({
                url: "/api/handover/print-pdf",
                method: "POST",
                data: {
                    id,
                },
                beforeSend: function (xhr) {
                    setCsrfHeader(xhr);
                    $('.background1').removeClass('hidden');
                },
                success: (res) => {
                    if (res.success == 1) {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "success",
                            timer: 500,
                            showConfirmButton: false
                        }).then((result) => {
                            linkPDF = `/handover/${id}.pdf`
                            var pdfWindow = window.open(`/handover/${id}.pdf`, "_blank")
                            pdfWindow.onload = function () {
                                window.location.reload();
                            };
                        })
                            .then(() => {
                                dataHandover()
                            });

                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        });
                    }

                },
                complete: function () {
                    $('.background1').addClass('hidden');
                }
            })
        }

        function confirmExportAll() {
            let namesAndCompanies = handovers.flatMap(elm => {
                if (Array.isArray(elm)) {
                    return elm.filter(item => item.isOpen === true).map(item => {
                        let name = item?.staff?.name || 'Tên không rõ';
                        let company = item?.staff?.company || 'Công ty không rõ';
                        return `${name} - ${company}`;
                    });
                }
                else {
                    return [];
                }
            }).join('<br>');

            if (namesAndCompanies.length > 0) {
                let scrollableNamesAndCompanies = `
                <div style="max-height: 150px; overflow-y: auto; margin-top: 10px;">
                    ${namesAndCompanies}
                </div>
            `;
                let confirmText = `
                Bạn có muốn xuất tất cả các phiếu đang mở cho các nhân viên sau không?
            ` + scrollableNamesAndCompanies;

                Swal.fire({
                    title: 'Xác nhận',
                    html: confirmText,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#3085d6',
                    cancelButtonColor: '#d33',
                    confirmButtonText: 'Đồng ý',
                    cancelButtonText: 'Hủy bỏ'
                }).then((result) => {
                    if (result.isConfirmed) {
                        exportAll();
                    }
                });
            } else {
                exportAll();
            }
        }



        function exportAll() {
            $.ajax({
                url: "/api/handover/export",
                method: "POST",
                beforeSend: function (xhr) {
                    setCsrfHeader(xhr);
                    $('.background1').removeClass('hidden');
                },
                success: (res) => {
                    if (res.success == 1) {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "success",
                            timer: 1000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        });
                    }
                },
                complete: function () {
                    $('.background1').addClass('hidden');
                }
            });
        }

        renderHandover(handovers)
    </script>

</html>
