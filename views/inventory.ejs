        function requestHandoverDevice(deviceId) {
            Swal.fire({
                title: "Yêu cầu bàn giao",
                input: "textarea",
                inputLabel: "Ghi chú của nhân viên",
                inputPlaceholder: "Nhập ghi chú...",
                showCancelButton: true,
                confirmButtonText: "Gửi yêu cầu",
                cancelButtonText: "Hủy",
                inputValidator: (value) => {
                    if (!value || value.trim().length === 0) {
                        return "Ghi chú của nhân viên không được để trống.";
                    }
                }
            }).then((result) => {
                if (!result.isConfirmed) {
                    return;
                }

                $.ajax(GVS.setting(GVS.requestHandoverDevice, 'POST', {
                    devices: [deviceId],
                    note_staff: result.value.trim(),
                    type: 1
                })).done(res => {
                    if (res.success == 1) {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "success",
                            confirmButtonText: "OK",
                        }).then(() => {
                            location.reload();
                        })
                    } else {
                        Swal.fire({
                            title: "Thông báo!",
                            text: res.message,
                            icon: "error",
                            confirmButtonText: "OK",
                        })
                    }
                }).fail(err => {
                    Swal.fire({
                        title: "Thông báo!",
                        text: err.responseJSON?.message || "Không thể gửi yêu cầu bàn giao.",
                        icon: "error",
                        confirmButtonText: "OK",
                    })
                })
            })
        }
