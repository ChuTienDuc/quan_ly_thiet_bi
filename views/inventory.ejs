                    for (const [key, value] of Object.entries(result)) {
                        if (value > 1) {
                            htmlCase += `x${value} ${key} </p>`
                        }
                        else
                            htmlCase += `${key} </p>`
                    }
                    htmlCase += `
                        <p> VGA: `
