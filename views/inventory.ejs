        function dataInventory() {
            $.ajax({
                url: GVS.GetAllInventories,
                method: "GET",
                success: (res) => {

                    inventorys.push(res.metadata)
                    renderInventory(res.metadata)
                    $("#table_inventory").DataTable()

                }
            })
        }
        function renderInventory(inventorys) {
            var html = ''
            inventorys.forEach((el, index) => {
                if (el.type == 'case') {
                    html += renderAttrCase(el.device)
                }
                if (el.type == 'monitor') {

                    html += renderAttrMonitor(el.device)
                }
                if (el.type == 'wacom') {

                    html += renderAttrWacom(el.device)
                }
                if (el.type == 'webcam') {

                    html += renderAttrWebcam(el.device)
                }
                if (el.type == 'headphone') {

                    html += renderAttrHeadphone(el.device)
                }
            })
            $('#data_inventory').html(html)
        }

