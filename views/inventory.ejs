                    })
                    htmlCase += `    
                        <p> Ổ cứng :`
                    el.device.attributes.hardDrives.forEach((el, index) => {
                        htmlCase += ` ${el.brand} ${el.size} ${el.type} </p>`
                    })

                    htmlCase += `
                            </td>
                            <td>`
                    if (el.device.status == 0) {
                        htmlCase += `Using `
                    }
                    else htmlCase += `Free`
                    htmlCase += `
                            </td>
                            <td>${el.quantity ?? 0}</td>
                            <td>${el.device.supplier?.address ?? ''}</td>
