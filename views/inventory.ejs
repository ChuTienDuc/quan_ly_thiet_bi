    <style>
        #table_inventory th,
        td {
            white-space: nowrap;
        }

        /* Tổng thể menu dropdown */
        .custom-dropdown-menu {
            z-index: 1050;
            background-color: #ffffff;
            /* Màu nền trắng */
            border: 1px solid #dee2e6;
            /* Đường viền nhẹ */
            border-radius: 0.25rem;
            /* Bo góc */
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15);
            /* Hiệu ứng đổ bóng */
            transform: translate3d(0, 0, 0);
            /* Đặt vị trí */
        }

        /* Phần tử trong menu */
        .custom-dropdown-menu .link-action {
            text-align: center;
            padding: 0.25rem 0.5rem;
            cursor: pointer;
            transition: background-color 0.3s ease;
            /* Hiệu ứng hover mượt */
        }

        /* Liên kết trong menu */
        .custom-dropdown-menu .dropdown-link {
            text-decoration: none;
            /* Xóa gạch chân */
            color: #212529;
            /* Màu chữ */
            font-size: 1rem;
            /* Kích thước chữ */
            display: block;
            /* Hiển thị block để dễ căn chỉnh */
            width: 100%;
            /* Chiếm toàn bộ chiều rộng */
            /* Khoảng cách bên trong */
        }

        /* Hiệu ứng hover */
        .custom-dropdown-menu .link-action:hover {
            background-color: #f8f9fa;
            /* Màu nền khi hover */
        }

        /* Nút trong menu */
        .custom-dropdown-menu button.dropdown-link {
            border: none;
            background-color: transparent;
            color: #212529;
            text-align: center;
            width: 100%;
        }

        /* Điều chỉnh vị trí của dropdown khi hiển thị */
        .dropdown-menu.show {
            position: absolute;
            top: calc(100% + 5px) !important;
            /* Cách nút kích hoạt một chút */
            left: 0;
            transform: translate3d(0%, 0%, 0) !important;
            /* Loại bỏ translate3d */
        }
    </style>

