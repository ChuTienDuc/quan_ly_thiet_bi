<!DOCTYPE html>
<html lang="en">
<%- include("./header.html") %>
    <link rel="stylesheet" href="/stylesheets/monitor.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.4/css/dataTables.bootstrap5.min.css">
    <style>
        #table_monitor {
            table-layout: fixed;
        }

        #table_monitor th {
            width: max-content !important;
        }

        #inputNumPreview::-webkit-outer-spin-button,
        #inputNumPreview::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }

        .connector_monitor {
            color: rgba(10, 20, 108, 1);
            border: none;
            border-radius: 0;
            border-bottom: 2px solid #c7c7c7 !important;
        }

        .connector_monitor:focus {
            border-color: #c7c7c7;
            box-shadow: none;

        }
    </style>

    <body id="body-pd" class="body-pd">
        <%- include("./nav.html") %>
            <div class="height-100 ">
                <main class="content p-0 pt-4">
                    <div class="container-fluid p-0">
                        <div class="row mt-5 pt-0 py-3 justify-content-between ">
                            <div class="col-5" style="width: max-content;">
                                <h3 class="color_header">Quản lý màn hình</h3>
                            </div>
                            <button class="col-1 btn bg-color-all c-white" onclick="renderOptionSupplier()"
                                data-bs-toggle="modal" data-bs-target="#addDevice"
                                style="width: max-content; border-radius: 29px;">Thêm màn
                                hình</button>
                        </div>

                        <div class="row">
                            <div class="col-12  d-flex">
                                <div class="card flex-fill"
                                    style="overflow-x:auto; overflow-x: scroll; max-height: 85vh;">

                                    <table class="table table-hover table-bordered  my-0 text-center" id="table_monitor"
                                        style="width: max-content !important; min-width: 100%;">
                                        <thead class="th_table_sticky">
                                            <tr class="align-middle text-center">
                                                <th class="col text-center ">
                                                    <span>Chi tiết</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Số tem</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Tên màn hình</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Cổng kết nối</span>
                                                </th>
                                                <!-- <th class="col text-center">
                                            <span>Tổng giá</span>
                                        </th> -->
                                                <th class="col text-center">
                                                    <span>Giá hóa đơn</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Trạng thái</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Nhà cung cấp</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Địa chỉ</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Tầng</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Ngày nhập kho</span>
                                                </th>
                                                <th class="col text-center">
                                                    <span>Hạn bảo hành</span>
                                                </th>
                                                <th class="col text-center text-break">
                                                    <span>Ghi chú</span>
                                                </th>
                                            </tr>
                                        </thead>
                                        <tbody id="content_table">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </main>
            </div>
            <!-- TODO MODAL ADD Monitor -->
            <div class="modal fade modal-xl" id="addDevice" tabindex="-1" aria-labelledby="exampleModalLabel"
                data-bs-backdrop="static">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content text-black">
                        <div class="modal-header text-center border-bottom-0">
                            <b class="modal-title f-s-24 font-weight-bold color_header" id="addDeviceLabel">
                                Thêm màn hình
                            </b>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"
                                onclick="deleteInput()"></button>
                        </div>

                        <div class="modal-body f-s-16 container pb-0">
                            <div id="input_monitor">
                                <div class="row justify-content-center">
                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center">
                                            <div class="col-3">
                                                <label for="quantity" class="col-form-label color_title_add_device">Số
                                                    lượng:
                                                </label>
                                            </div>
                                            <div class="col-7">
                                                <input type="number" min="1" step="1" id="quantity" class="form-control"
                                                    placeholder="Nhập số lượng màn hình">
                                            </div>

                                        </div>
                                    </div>
                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center">
                                            <div class="col-3" style="width: max-content;">
                                                <label for="_id" class="col-form-label color_title_add_device">Số tem:
                                                </label>
                                            </div>
                                            <div class="col-7">
                                                <input type="text" id="_id_monitor" class="form-control"
                                                    name="_idmonitor" placeholder="Nhập số màn hình">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center"
                                            onmouseover="showDeleteAndAddConnector(this)"
                                            onmouseout="hiddenDeleteAndAddConnector(this)">
                                            <div class="col-3 ">
                                                <label class="col-form-label color_title_add_device"
                                                    for="connect_addmonitor">Cổng kết nối:
                                                </label>
                                            </div>
                                            <div class="col-6 mb-2">
                                                <select class="form-select form-select-md connector_monitor"
                                                    name="connector_0" aria-label=".form-select-lg example">
                                                    <option value="VGA">VGA</option>
                                                    <option value="DVI">DVI</option>
                                                    <option value="HDMI" selected>HDMI</option>
                                                    <option value="DisplayPort">DisplayPort</option>
                                                    <option value="Mini-DP">Mini-DP</option>
                                                    <option value="Type-C">Type-C</option>
                                                </select>
                                            </div>
                                            <div class="col-1 ps-0 d-flex">
                                                <button class="btn btn_add btn_add_connnector mt-2 d-none"
                                                    onclick="addConnector(this)"><i class="fa fa-plus"></i>
                                                </button>
                                                <i class="fa fa-x d-flex align-items-center mt-1 ms-2 d-none"
                                                    style="cursor: pointer;"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row justify-content-center">
                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center">
                                            <div class="col-3">
                                                <label for="name_addmonitor"
                                                    class="col-form-label color_title_add_device">Tên
                                                    màn
                                                    hình:</label>
                                            </div>
                                            <div class="col-7 mb-2">
                                                <input type="text" id="name_addmonitor" list="datalistname"
                                                    autocomplete="off" class="form-control"
                                                    placeholder="Nhập tên màn hình">
                                                <div class="invalid-feedback">Vui lòng nhập tên màn hình</div>

                                            </div>
                                        </div>
                                    </div>

                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center">
                                            <div class="col-3" style="width: max-content;">
                                                <label for="expirationDate"
                                                    class="col-form-label color_title_add_device">Hạn
                                                    bảo hành:
                                                </label>
                                            </div>
                                            <div class="col-7">
                                                <input type="date" id="expirationDate" class="form-control" 0
                                                    placeholder="Nhập Expiration Date">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="row justify-content-center">
                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center">
                                            <div class="col-3">
                                                <label for="bill_price"
                                                    class="col-form-label color_title_add_device">Giá hóa
                                                    đơn:</label>
                                            </div>
                                            <div class="col-7 mb-2" style="position: relative;">
                                                <input type="text" id="bill_price" list="datalistbillprice"
                                                    autocomplete="off" class="form-control" placeholder="Giá hóa đơn">
                                                <div class="invalid-feedback">Vui lòng nhập giá hóa đơn</div>
                                                <div style="position: absolute;top: 5.5%;right: 11%; color: #163EB1;">
                                                    VND</div>

                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6 mb-3" style="position: relative;">
                                        <div class="row justify-content-center">
                                            <div class="col-3">
                                                <label for="total_price"
                                                    class="col-form-label color_title_add_device">Tổng
                                                    giá:</label>
                                            </div>
                                            <div class="col-7 mb-2">
                                                <input disabled type="text" id="total_price" class="form-control"
                                                    placeholder="Nhập tổng giá">
                                                <div style="position: absolute;top: 5.5%;right: 11%; color: #163EB1;">
                                                    VND</div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="row justify-content-center mb-3">
                                    <div class="col-6 mb-3">
                                        <div class="row justify-content-center">
                                            <div class="col-3 " style="width: max-content;">
                                                <label for="supplier_addmonitor"
                                                    class="col-form-label color_title_add_device">Nhà cung cấp:
                                                </label>
                                            </div>
                                            <div class="col-6">

                                                <select class="form-select form-select-md supplier"
                                                    id="supplier_addmonitor" aria-label=".form-select-lg example">
                                                    <option></option>
                                                </select>

                                            </div>
                                            <div class="col-1 ps-0 d-flex align-items-end"><button
                                                    data-bs-target="#create_supplier" data-bs-toggle="modal"
                                                    class="btn btn_add" id="createSupplier"><i
                                                        class="fa fa-plus text-white"></i></button>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="row justify-content-center">
                                            <div class="input-group" style="max-width: 83%;">
                                                <span class="input-group-text">Ghi chú</span>
                                                <textarea class="form-control p-0" autocomplete="off"
                                                    id="note_addmonitor" aria-label="With textarea"></textarea>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row justify-content-center mb-4">
                                <div class="col-11 d-flex justify-content-end pe-0">
                                    <div class="row"></div>
                                    <button class="btn btn-primary py-2" id="preview" style="border-radius: 29px;
                            background: #30689E;">Xem trước</button>
                                </div>
                            </div>
                            <div class="row mt-3 justify-content-center" id="table_preview">
                                <div class="col-10">
                                    <table class="table table-bordered">
                                        <thead>
                                            <tr class="text-center">
                                                <th scope="col" style="width: max-content;">Số tem</th>
                                                <th scope="col" style="width: max-content;">Cổng kết nối</th>
                                                <th scope="col" style="width: max-content;">Tên màn hình</th>
                                                <th scope="col" style="width: max-content;">Nhà cung cấp</th>
                                                <th scope="col" style="width: max-content;">Giá hóa đơn</th>
                                                <th scope="col"></th>
                                                <th scope="col"></th>
                                            </tr>
                                        </thead>
                                        <tbody id="dataCreate" class="text-center">
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal fade modal-lg" id="create_supplier" aria-hidden="true"
                aria-labelledby="exampleModalToggleLabel2" tabindex="-1" data-bs-backdrop="static">
            </div>
            <script src="/javascripts/fomat.js"></script>
            <script src="/javascripts/monitor.js"></script>
            <!-- <script src="/javascripts/GVS.js"></script> -->
            <script src="/javascripts/autocomplete.js"></script>
            <script src="/javascripts/supplier.js"></script>
    </body>

</html>